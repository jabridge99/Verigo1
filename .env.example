# ─────────────────────────────────────────────────────────────────────────────
# Verigo — Environment Configuration
# Copy to .env and fill in all required values before deploying.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Domains (used by Nginx, API CORS, and frontend build) ────────────────────
# These two variables are the single source of truth for your domain.
# Set them once here — everything else derives from them.
APP_DOMAIN=app.yourdomain.com   # ← REQUIRED — frontend domain
API_DOMAIN=api.yourdomain.com   # ← REQUIRED — backend API domain

# ── TLS / Let's Encrypt ───────────────────────────────────────────────────────
# Set CERTBOT_EMAIL to auto-provision free Let's Encrypt certs on first boot.
# Leave blank to use self-signed certs (dev/staging only — not trusted by browsers).
CERTBOT_EMAIL=                  # e.g. ops@yourdomain.com
CERTBOT_STAGING=false           # true = use Let's Encrypt staging (no rate limits)

# ── App identity ──────────────────────────────────────────────────────────────
ENVIRONMENT=production          # development | staging | production
LOG_LEVEL=INFO

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project settings → API in the Supabase dashboard
SUPABASE_URL=https://your-ref.supabase.co           # ← REQUIRED
SUPABASE_ANON_KEY=eyJ...                            # ← REQUIRED (public, used by frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJ...                    # ← REQUIRED (secret, backend only)

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase: Project Settings → Database → Connection string → URI (use the pooler URL)
# Dev: DATABASE_URL=sqlite:///./tvg.db
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME             # ← REQUIRED

# ── CORS ─────────────────────────────────────────────────────────────────────
# Derived from APP_DOMAIN above. Override here if you have multiple origins.
# REQUIRED in production — defaults to "*" which is unsafe for credentialed requests.
CORS_ORIGINS=https://app.yourdomain.com,https://www.yourdomain.com

# ── Redis ─────────────────────────────────────────────────────────────────────
# REQUIRED in production when running more than one API worker/instance.
# Used for: JWT revocation blacklist (multi-worker safe logout), rate limiting.
# Without this, JWT revocation and rate limits are per-process only.
REDIS_URL=redis://localhost:6379/0

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.CHANGE_ME
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Verigo

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Create these Price IDs in your Stripe dashboard (recurring, AUD)
STRIPE_STARTER_MONTHLY_ID=price_CHANGE_ME
STRIPE_STARTER_ANNUAL_ID=price_CHANGE_ME
STRIPE_PRO_MONTHLY_ID=price_CHANGE_ME
STRIPE_PRO_ANNUAL_ID=price_CHANGE_ME
STRIPE_ENT_MONTHLY_ID=price_CHANGE_ME
STRIPE_ENT_ANNUAL_ID=price_CHANGE_ME

# ── Identity verification (KYC/KYB) ───────────────────────────────────────────
IDENTITY_PROVIDER=internal       # internal | sumsub
SUMSUB_APP_TOKEN=
SUMSUB_SECRET_KEY=
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_LEVEL_NAME=basic-kyc-level
SUMSUB_KYB_LEVEL_NAME=basic-kyb-level
SUMSUB_UNIT_COST_AUD=2.50        # what Sumsub charges us per check
USAGE_MARKUP_PCT=50.0            # tenant is billed unit_cost * (1 + pct/100)

# ── Crypto wallet screening ────────────────────────────────────────────────────
# internal | chainalysis | ofac_sdn | crypto_apis | scorechain | goplus | trm_labs | elliptic
CRYPTO_PROVIDER=internal
# Chainalysis free sanctions-only oracle — sign up at chainalysis.com for an
# instant API key (no sales call). Free tier: 5000 requests / 5 min.
CHAINALYSIS_API_KEY=
# ofac_sdn needs no API key — self-hosted, fetches the community-maintained
# OFAC SDN crypto address lists from GitHub on a 6h in-memory cache.
# Crypto APIs "Verify Address" — real pay-as-you-go, no enterprise minimum.
CRYPTOAPIS_API_KEY=
# Scorechain free sanctions API — free tier, ~100 req/hour.
SCORECHAIN_API_KEY=
# GoPlus Security — has a free unauthenticated quota; key from their console
# raises the rate limit. EVM chains only (Ethereum/BSC/Polygon).
GOPLUS_API_KEY=
# Elliptic — enterprise wallet screening (sales-gated, no self-serve signup).
# Requests are HMAC-signed with both a key and a secret.
ELLIPTIC_API_KEY=
ELLIPTIC_API_SECRET=

# ── Workers ───────────────────────────────────────────────────────────────────
API_WORKERS=2      # Uvicorn workers — set to CPU count for production

# ── Document / file storage ───────────────────────────────────────────────────
# supabase — Supabase Storage (recommended for production — uses SUPABASE_* keys above)
# local    — stores files on disk (dev only, not suitable for multi-instance deployments)
# r2       — Cloudflare R2 (S3-compatible, free egress)
# s3       — AWS S3 or any other S3-compatible provider (Backblaze B2, MinIO)
# azure    — Azure Blob Storage
# gcs      — Google Cloud Storage
STORAGE_BACKEND=supabase
DOCUMENT_BUCKET=documents        # Supabase Storage bucket name (create in dashboard)
DOCUMENT_STORE_PATH=/data/uploads  # used only when STORAGE_BACKEND=local

# Cloudflare R2
# 1. Create a bucket: Cloudflare dashboard → R2 → Create bucket
# 2. Create an API token: R2 → Manage API Tokens → Create API Token
#    (grants an access key id / secret access key pair, NOT your Cloudflare login)
# 3. R2_ACCOUNT_ID is your Cloudflare account ID (shown on the R2 overview page)
R2_ACCOUNT_ID=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# S3 / Backblaze B2
S3_BUCKET=
S3_REGION=ap-southeast-2
S3_ENDPOINT_URL=                  # Leave blank for AWS; set for Backblaze/MinIO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Azure Blob Storage
AZURE_ACCOUNT_NAME=
AZURE_ACCOUNT_KEY=
AZURE_CONTAINER=documents

# Google Cloud Storage
GCS_BUCKET=
GCS_CREDENTIALS_JSON=            # Path to service-account JSON file

# ── OAuth / Social login (optional — leave blank to disable) ─────────────────
# Google: https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: https://API_DOMAIN/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Microsoft: https://portal.azure.com (App registrations)
#   Redirect URI: https://API_DOMAIN/api/v1/auth/oauth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common          # or your Azure AD tenant id for single-tenant apps

# ── Master admin (optional) ───────────────────────────────────────────────────
# If both are set, a global super-admin account (not tied to any tenant) is
# created on startup if it doesn't already exist. Leave blank to disable.
MASTER_ADMIN_EMAIL=
MASTER_ADMIN_PASSWORD=

# ── Observability (optional but recommended for production) ───────────────────
# Backend: create a project at https://sentry.io (Python/FastAPI platform).
# Leave blank to disable — the app runs fine without it.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Frontend: create a second Sentry project (Next.js platform). NEXT_PUBLIC_*
# vars are baked into the browser bundle, so this DSN is not secret.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ENVIRONMENT=production
# Only needed in CI/build environments to upload source maps for readable
# stack traces — leave blank to skip source map upload.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
