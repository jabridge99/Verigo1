# Smart E-Waste Platform configuration contract
# These are placeholder values for planning and implementation alignment only.

# Environment
APP_ENV=development
LOG_LEVEL=INFO

# Backend API
API_BASE_PATH=/api/v1
JWT_SECRET=replace-in-implementation
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_MINUTES=10080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ewaste
POSTGRES_USER=ewaste
POSTGRES_PASSWORD=replace-in-implementation
DATABASE_URL=postgresql://ewaste:replace-in-implementation@postgres:5432/ewaste

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# MQTT / IoT
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=replace-in-implementation
MQTT_PASSWORD=replace-in-implementation
MQTT_TOPIC_PREFIX=ewaste
DEVICE_OFFLINE_TIMEOUT_SECONDS=300
BIN_FULL_ALERT_THRESHOLD=90
BATTERY_LOW_ALERT_THRESHOLD=20

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=EcoLoop
NEXT_PUBLIC_MAP_PROVIDER=placeholder

# Deployment / Observability
SENTRY_DSN=placeholder
METRICS_ENABLED=false
