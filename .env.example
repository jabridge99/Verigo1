# ─────────────────────────────────────────────────────────────────────────────
# Trust Verify Go — Environment Configuration
# Copy to .env and fill in all required values before deploying.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App identity ──────────────────────────────────────────────────────────────
ENVIRONMENT=production          # development | staging | production
APP_URL=https://app.trustverifygo.com.au
API_URL=https://api.trustverifygo.com.au
LOG_LEVEL=INFO

# ── Database (PostgreSQL recommended for production) ──────────────────────────
# Dev: DATABASE_URL=sqlite:///./tvg.db
DATABASE_URL=postgresql://tvg:CHANGE_ME@db:5432/tvg
POSTGRES_DB=tvg
POSTGRES_USER=tvg
POSTGRES_PASSWORD=CHANGE_ME      # ← REQUIRED — use a strong random password

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME             # ← REQUIRED

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=https://app.trustverifygo.com.au,https://www.trustverifygo.com.au

# ── Email / SMTP ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.CHANGE_ME
FROM_EMAIL=noreply@trustverifygo.com.au
FROM_NAME=Trust Verify Go

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Create these Price IDs in your Stripe dashboard (recurring, AUD)
STRIPE_STARTER_MONTHLY_ID=price_CHANGE_ME
STRIPE_STARTER_ANNUAL_ID=price_CHANGE_ME
STRIPE_PRO_MONTHLY_ID=price_CHANGE_ME
STRIPE_PRO_ANNUAL_ID=price_CHANGE_ME
STRIPE_ENT_MONTHLY_ID=price_CHANGE_ME
STRIPE_ENT_ANNUAL_ID=price_CHANGE_ME

# ── Workers ───────────────────────────────────────────────────────────────────
API_WORKERS=2      # Uvicorn workers (set to CPU count for production)

# ── Document storage ──────────────────────────────────────────────────────────
DOCUMENT_STORE_PATH=/data/uploads
# For cloud storage, integrate boto3/azure-storage-blob and point to S3/GCS/Azure

# ── Observability (optional) ──────────────────────────────────────────────────
SENTRY_DSN=
